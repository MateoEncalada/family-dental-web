---
const { 
  title = "Family Dental — Odontología para toda la familia",
  description = "Cuidamos la salud bucal de toda tu familia en Ambato, Ecuador. Endodoncia, ortodoncia, odontopediatría e implantes. ¡Primera consulta gratis!",
  image = "/images/hero.jpg"
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:url" content={Astro.url} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Quicksand:wght@600;700;800&display=swap" rel="stylesheet" />
    
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        /* PALETA CLÍNICA Y AMIGABLE */
        --azul-dark:     #0F4A80;
        --azul:          #1A6FB5;
        --azul-light:    #E8F4FC;
        --magenta:       #E0287A;
        --magenta-light: #FDE8F1;
        --gris-claro:    #F4F7F9;
        --texto:         #1E293B;
        --gris:          #64748B;
        --blanco:        #FFFFFF;

        --font-display: 'Quicksand', sans-serif;
        --font-body:    'DM Sans', sans-serif;
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--gris-claro);
        color: var(--texto);
        font-family: var(--font-body);
        font-weight: 400;
        line-height: 1.6;
        overflow-x: hidden;
      }

      img { max-width: 100%; display: block; }
      a   { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>