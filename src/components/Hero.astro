<style>
.hero { min-height: 100vh; background: linear-gradient(135deg, var(--azul-dark) 0%, var(--azul) 60%, #2589D4 100%); color: white; display: flex; flex-direction: column; position: relative; overflow: hidden; }
.hero::before { content: ''; position: absolute; top: -30%; right: -10%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%); pointer-events: none; }
.hero::after { content: ''; position: absolute; bottom: -20%; left: -5%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(224,40,122,0.12) 0%, transparent 70%); pointer-events: none; }
.nav { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 4rem; position: relative; z-index: 2; }
.logo-text { display: flex; flex-direction: column; line-height: 1; }
.logo-family { font-family: var(--font-display); font-size: 1.6rem; font-weight: 800; color: white; letter-spacing: -0.01em; }
.logo-dental { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--magenta); letter-spacing: 0.15em; text-transform: uppercase; }

/* ESTILOS DEL NUEVO MENÚ */
.nav-links { display: flex; gap: 2.5rem; align-items: center; }
.nav-links a { font-size: 0.95rem; font-weight: 600; color: rgba(255,255,255,0.8); transition: color 0.3s; }
.nav-links a:hover { color: #7DD3FC; }

.nav-info { display: flex; align-items: center; gap: 1.5rem; font-size: 0.88rem; color: rgba(255,255,255,0.75); }
.nav-cta { background: var(--magenta); color: white; padding: 0.5rem 1.4rem; border-radius: 999px; font-weight: 600; font-size: 0.85rem; transition: all 0.3s; }
.nav-cta:hover { background: #c01f68; transform: translateY(-1px); }
.hero-inner { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; padding: 2rem 4rem 5rem; position: relative; z-index: 2; }
.hero-badge { display: inline-block; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25); backdrop-filter: blur(10px); color: white; font-size: 0.82rem; font-weight: 600; padding: 0.4rem 1rem; border-radius: 999px; margin-bottom: 1.4rem; }
h1 { font-family: var(--font-display); font-size: clamp(2.4rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.1; color: white; margin-bottom: 1.4rem; }
h1 em { color: #7DD3FC; font-style: normal; }
.hero-sub { font-size: 1rem; color: rgba(255,255,255,0.72); max-width: 440px; line-height: 1.7; margin-bottom: 2.2rem; }
.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.btn-primary { display: inline-flex; align-items: center; gap: 0.6rem; background: var(--magenta); color: white; padding: 0.85rem 1.8rem; border-radius: 999px; font-weight: 600; font-size: 0.92rem; transition: all 0.3s; box-shadow: 0 4px 20px rgba(224,40,122,0.4); }
.btn-primary:hover { background: #c01f68; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(224,40,122,0.5); }
.btn-outline { display: inline-flex; align-items: center; border: 2px solid rgba(255,255,255,0.3); color: white; padding: 0.83rem 1.6rem; border-radius: 999px; font-weight: 500; font-size: 0.92rem; transition: all 0.3s; }
.btn-outline:hover { background: rgba(255,255,255,0.1); border-color: white; }
.hero-datos { display: flex; flex-direction: column; gap: 0.6rem; }
.dato { display: flex; align-items: center; gap: 0.6rem; font-size: 0.85rem; color: rgba(255,255,255,0.65); }
.dato-icon { font-size: 1rem; }
.hero-visual { position: relative; display: flex; justify-content: center; }
.hero-img, .img-placeholder { width: 100%; max-width: 480px; aspect-ratio: 4/5; border-radius: 2rem; overflow: hidden; display: flex; align-items: center; justify-content: center; }
.badge-float { position: absolute; background: white; border-radius: 1rem; padding: 0.9rem 1.2rem; box-shadow: 0 8px 30px rgba(0,0,0,0.15); display: flex; align-items: center; gap: 0.6rem; color: var(--texto); }
.badge-1 { bottom: 2.5rem; left: -1rem; flex-direction: column; text-align: center; gap: 0.1rem; }
.badge-1 strong { font-family: var(--font-display); font-size: 1.6rem; font-weight: 800; color: var(--azul); display: block; }
.badge-1 span { font-size: 0.72rem; color: var(--gris); line-height: 1.4; }
.badge-2 { top: 2rem; right: -1rem; flex-direction: column; text-align: center; gap: 0.1rem; }
.badge-icon { font-size: 1.4rem; }
.badge-2 span { font-size: 0.75rem; color: var(--gris); line-height: 1.4; }
.badge-2 strong { color: var(--magenta); }

/* RESPONSIVE */
@media (max-width: 768px) {
  .nav { padding: 1.2rem 1.5rem; }
  .nav-info span { display: none; }
  
  /* En celular ocultamos los links porque no caben, dejamos solo el logo y el botón */
  .nav-links { display: none; } 

  .hero-inner { grid-template-columns: 1fr; padding: 1.5rem 1.5rem 3rem; gap: 3rem; text-align: center; }
  .hero-sub { margin: 0 auto 2.2rem; }
  .hero-btns { justify-content: center; }
  .hero-datos { align-items: center; }
  .hero-visual { order: -1; margin-top: 1rem; width: 100%; }
  .hero-img, .img-placeholder { aspect-ratio: 1/1; max-width: 100%; }
  .badge-1 { left: 50%; transform: translateX(-50%); bottom: -2rem; width: max-content; flex-direction: row; text-align: left;}
  .badge-2 { right: 50%; transform: translateX(50%); top: -1.5rem; width: max-content; flex-direction: row; text-align: left; }
}
</style>