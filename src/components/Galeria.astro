---
---
<section class="galeria" id="galeria">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <p class="section-tag">Nuestras instalaciones</p>
      <h2>Las mejores instalaciones<br/><em>para tus hijos</em></h2>
    </div>

    <div class="swiper swiper-galeria" data-aos="fade-up" data-aos-delay="200">
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <div class="item-galeria"><img src="/images/g1.jpg" alt="Niño en consultorio" /></div>
        </div>
        <div class="swiper-slide">
          <div class="item-galeria"><img src="/images/g2.jpg" alt="Instalaciones" /></div>
        </div>
        <div class="swiper-slide">
          <div class="item-galeria"><img src="/images/img1.jpg" alt="Equipo médico" /></div>
        </div>
        <div class="swiper-slide">
          <div class="item-galeria"><img src="/images/img2.jpg" alt="Tratamiento" /></div>
        </div>
        <div class="swiper-slide">
          <div class="item-galeria"><img src="/images/img3.jpg" alt="Sonrisa resultado" /></div>
        </div>
      </div>
      
      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
</section>

<style>
.galeria { background: white; padding: 6rem 0; overflow: hidden; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 4rem; position: relative; }
.section-header { text-align: center; margin-bottom: 3rem; }
.section-tag { font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--magenta); margin-bottom: 0.6rem; font-weight: 700; }
h2 { font-family: var(--font-display); font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 800; color: var(--texto); line-height: 1.2; }
h2 em { color: var(--azul); font-style: normal; }

/* ESTILOS DEL CARRUSEL */
.swiper-galeria { padding-bottom: 4rem; }
.item-galeria { border-radius: 1.2rem; overflow: hidden; background: var(--azul-light); aspect-ratio: 4/3; }
.item-galeria img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
.item-galeria:hover img { transform: scale(1.05); }

/* Pintar flechas y puntos de color magenta */
:global(.swiper-button-next), :global(.swiper-button-prev) { color: var(--magenta) !important; }
:global(.swiper-pagination-bullet-active) { background: var(--magenta) !important; }

@media (max-width: 768px) {
  .container { padding: 0 1.5rem; }
  .galeria { padding: 4rem 0; }
  /* En celular ocultamos las flechas, la gente arrastra con el dedo */
  :global(.swiper-button-next), :global(.swiper-button-prev) { display: none; }
}
</style>