<style>
.footer {
  background: var(--azul-dark);
  color: white;
  padding: 4rem 4rem 2rem;
}

.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1.5fr;
  gap: 3rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  margin-bottom: 1.5rem;
}

.logo-text {
  display: flex;
  flex-direction: column;
  line-height: 1;
  margin-bottom: 1rem;
}
.logo-family {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 900;
  color: white;
}
.logo-dental {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--magenta);
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.footer-brand p {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
  max-width: 260px;
}

.footer-title {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin-bottom: 0.8rem;
  font-weight: 600;
}

.footer-links {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.footer-links a {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.6);
  transition: color 0.2s;
}
.footer-links a:hover { color: white; }

.footer-contact {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.footer-contact p {
  font-size: 0.84rem;
  color: rgba(255,255,255,0.6);
}
.footer-wpp {
  margin-top: 0.5rem;
  font-size: 0.9rem;
  font-weight: 600;
  color: #7DD3FC;
  transition: color 0.2s;
}
.footer-wpp:hover { color: white; }

.footer-bottom {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.footer-bottom p {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.3);
}
.footer-consulta { color: rgba(255,255,255,0.5) !important; }

/* BOTÓN FLOTANTE */
.wpp-float {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  background: #25D366;
  color: white;
  border-radius: 999px;
  padding: 0.85rem 1.4rem 0.85rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  box-shadow: 0 6px 24px rgba(37,211,102,0.4);
  z-index: 999;
  transition: all 0.3s;
  font-weight: 600;
  font-size: 0.88rem;
}
.wpp-float:hover {
  transform: translateY(-3px) scale(1.03);
  box-shadow: 0 10px 32px rgba(37,211,102,0.5);
}

@media (max-width: 768px) {
  .footer { padding: 3rem 1.5rem 1.5rem; }
  .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
  .footer-bottom { justify-content: center; text-align: center; }
  .wpp-float { bottom: 1.2rem; right: 1.2rem; padding: 1rem; border-radius: 50%; }
  .wpp-label { display: none; }
}
</style>