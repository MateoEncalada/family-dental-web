---
const servicios = [
  { icon: "🦷", nombre: "Endodoncia", desc: "Tratamiento del nervio dental. Salva tu diente eliminando la infección desde la raíz.", incluye: ["Anestesia local", "Remoción de la pulpa", "Curación de conductos"], color: "azul" },
  { icon: "😁", nombre: "Ortodoncia", desc: "Brackets y aparatos para alinear tus dientes y conseguir la sonrisa que siempre quisiste.", incluye: ["Consulta inicial", "Aparatos ortodónticos", "Ajustes y seguimiento"], color: "magenta" },
  { icon: "👨‍👩‍👧", nombre: "Odontopediatría", desc: "Cuidado dental especializado para niños, en un ambiente amigable y sin miedo.", incluye: ["Revisión preventiva", "Sellantes", "Flúor y limpieza"], color: "azul" },
  { icon: "✨", nombre: "Estética dental", desc: "Blanqueamiento, carillas y más para que tu sonrisa brille con confianza.", incluye: ["Blanqueamiento", "Carillas", "Resinas estéticas"], color: "magenta" },
  { icon: "🔩", nombre: "Implantes", desc: "Reemplaza dientes perdidos con implantes de titanio que duran toda la vida.", incluye: ["Implante de titanio", "Corona definitiva", "Seguimiento completo"], color: "azul" },
  { icon: "🧹", nombre: "Limpieza dental", desc: "Profilaxis profesional para mantener tus encías y dientes en perfecto estado.", incluye: ["Detartraje", "Pulido dental", "Instrucción de higiene"], color: "magenta" },
];
---

<section class="servicios" id="servicios">
  <div class="container">
    <div class="section-header" data-aos="fade-up">
      <p class="section-tag">Lo que hacemos</p>
      <h2>Nuestros <em>servicios</em></h2>
      <p class="section-sub">Atención completa para toda la familia. El Dr. Víctor Encalada y su equipo están listos para cuidarte.</p>
    </div>

    <div class="grid">
      {servicios.map((s, i) => (
        <div class={`card card-${s.color}`} data-aos="fade-up" data-aos-delay={i * 100}>
          <div class="card-icon">{s.icon}</div>
          <h3>{s.nombre}</h3>
          <p>{s.desc}</p>
          <ul class="incluye">
            {s.incluye.map((item) => (
              <li>✓ {item}</li>
            ))}
          </ul>
          <a
            href={`https://wa.me/593997137230?text=Hola! Quiero info sobre ${s.nombre}`}
            target="_blank"
            class="card-btn"
          >
            Consultar →
          </a>
        </div>
      ))}
    </div>

    <div class="cta-box" data-aos="zoom-in" data-aos-delay="200">
      <div class="cta-text">
        <h3>¿No sabes qué necesitas?</h3>
        <p>La primera consulta con el Dr. Encalada es <strong>completamente gratis</strong>. Él te evalúa y te recomienda el tratamiento ideal.</p>
      </div>
      <a href="https://wa.me/593997137230?text=Hola! Quiero agendar mi consulta gratuita" target="_blank" class="btn-cta">
        Agendar consulta gratis
      </a>
    </div>
  </div>
</section>

<style>
.servicios { background: var(--gris-claro); padding: 6rem 0; overflow-x: hidden; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 4rem; }
.section-header { text-align: center; margin-bottom: 4rem; }
.section-tag { font-size: 0.8rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--magenta); margin-bottom: 0.6rem; font-weight: 600; }
h2 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; color: var(--texto); margin-bottom: 0.8rem; }
h2 em { color: var(--azul); font-style: normal; }
.section-sub { color: var(--gris); font-size: 1rem; max-width: 500px; margin: 0 auto; }
.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; }

.card { background: white; border-radius: 1.2rem; padding: 2rem; border: 1.5px solid transparent; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative; overflow: hidden; }
.card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px; border-radius: 1.2rem 1.2rem 0 0; }
.card-azul::before    { background: var(--azul); }
.card-magenta::before { background: var(--magenta); }

/* Cuando pasas el mouse por la tarjeta, salta un poquito más suave y proyecta sombra */
.card:hover { transform: translateY(-8px); box-shadow: 0 16px 40px rgba(26,111,181,0.15); }
.card-azul:hover    { border-color: var(--azul-light); }
.card-magenta:hover { border-color: var(--magenta-light); }

/* ANIMACIÓN PARA EL ICONO AL PASAR EL MOUSE */
.card-icon { font-size: 2.2rem; margin-bottom: 1rem; transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: inline-block; }
.card:hover .card-icon {
  transform: scale(1.3) rotate(10deg); /* El icono se agranda y se gira un poquito */
}

.card h3 { font-family: var(--font-display); font-size: 1.2rem; font-weight: 800; color: var(--texto); margin-bottom: 0.5rem; }
.card p { font-size: 0.88rem; color: var(--gris); line-height: 1.6; margin-bottom: 1rem; }
.incluye { list-style: none; margin-bottom: 1.5rem; }
.incluye li { font-size: 0.82rem; color: var(--texto); padding: 0.2rem 0; opacity: 0.75; }
.card-btn { font-size: 0.88rem; font-weight: 600; display: inline-block; transition: transform 0.2s; }
.card-azul .card-btn    { color: var(--azul); }
.card-magenta .card-btn { color: var(--magenta); }
.card:hover .card-btn { transform: translateX(5px); /* La flechita se mueve un poco a la derecha */ }

/* CTA BOX */
.cta-box { background: linear-gradient(135deg, var(--azul-dark), var(--azul)); border-radius: 1.5rem; padding: 2.5rem 3rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; color: white; }
.cta-text h3 { font-family: var(--font-display); font-size: 1.4rem; font-weight: 800; margin-bottom: 0.5rem; }
.cta-text p { font-size: 0.92rem; opacity: 0.8; max-width: 460px; }
.cta-text strong { color: #7DD3FC; }
.btn-cta { white-space: nowrap; background: var(--magenta); color: white; padding: 0.9rem 2rem; border-radius: 999px; font-weight: 700; font-size: 0.9rem; transition: all 0.3s; box-shadow: 0 4px 16px rgba(224,40,122,0.35); flex-shrink: 0; }
.btn-cta:hover { background: #c01f68; transform: translateY(-2px); }

@media (max-width: 768px) {
  .container { padding: 0 1.5rem; }
  .servicios { padding: 4rem 0; }
  .cta-box { flex-direction: column; text-align: center; padding: 2rem 1.5rem; }
}
</style>